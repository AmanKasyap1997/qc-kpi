{
  "name": "qc-kpi",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run build -w frontend",
    "lint:frontend": "npm run lint -w frontend",
    "seed": "npm run seed -w backend",
    "import:run": "npm run import:run -w backend",
    "import:cron": "npm run import:cron -w backend",
    "import:test": "npm run import:test -w backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "node-cron": "^4.2.1",
    "winston": "^3.19.0"
  }
}
