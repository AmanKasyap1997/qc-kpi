# ══════════════════════════════════════════════════════════════
#  CITY COMPANIES PLATFORM — ENVIRONMENT VARIABLES
#  Copy to .env and fill in all values before starting.
# ══════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173/

# DATABASE
DB_HOST=db_host
DB_PORT=db_port
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=password
DB_SSL=false

# DATABASE_URL="postgresql://city_platform:postgres@localhost:5432/city_platform?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/city_platform?schema=public"

# JWT AUTH
JWT_SECRET=your_256_bit_secret_here_change_this
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=your_refresh_secret_here_change_this
JWT_REFRESH_EXPIRES_IN=7d

# REDIS
REDIS_URL=redis://localhost:6379

# TWILIO (SMS alerts — Nick gets CRITICAL alerts instantly)
TWILIO_ACCOUNT_SID=account_sid
TWILIO_AUTH_TOKEN=auth_token
TWILIO_FROM_NUMBER=from_number
NICK_PHONE_NUMBER=nick_phone_number

# EMAIL REPORTS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=reports@citydebtrelief.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="City Companies Platform <reports@citydebtrelief.com>"
REPORT_EMAIL_NICK=nick@citydebtrelief.com
REPORT_EMAIL_OPS=ops@citydebtrelief.com

WEBHOOK_URL=webhook_url

# RINGSENSE
RINGSENSE_API_URL=ringsense_api_url
RINGSENSE_API_KEY=your_ringsense_api_key
RINGSENSE_WEBHOOK_SECRET=your_ringsense_webhook_secret

# GOHIGHLEVEL
GHL_API_URL=ghl_api_url
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# ZENDESK
ZENDESK_API_URL=zendesk_api_url
ZENDESK_EMAIL=zendesk_email
ZENDESK_API_TOKEN=zendesk_token
ZENDESK_WEBHOOK_SECRET=your_zendesk_webhook_secret

# ADMIN (used by database/seed.js)
ADMIN_EMAIL=admin_email
ADMIN_PASSWORD=your_secure_password

# API KEY (machine auth — gates all /api/* endpoints; does not expire)
API_KEY=api_verification_key


CALLERREADY_API_KEY=caller_ready_api_key
CALLERREADY_BASE_URL=caller_ready_base_url

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

